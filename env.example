# Nova Nest Real Estate - Local Development Environment Variables (Example)
# Copy this file to .env.local and fill in real values. Do NOT commit secrets.

# --- Supabase configuration ---
# Public URL of your Supabase project (used on client and server)
NEXT_PUBLIC_SUPABASE_URL=
# Public (anon) key for Supabase (safe to expose on client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key for Supabase (SERVER ONLY - never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# --- Google services ---
# Google Maps JavaScript API key (client-side usage for maps)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Google My Business API key (placeholder - fill if integrating GMB)
GOOGLE_MY_BUSINESS_API_KEY=

# --- Email service ---
# Resend API key for transactional emails
RESEND_API_KEY=
# From address for outgoing emails
SMTP_FROM_EMAIL=info@novanest.bg

# --- Analytics & Webmaster tools ---
# Google Analytics Measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Google Search Console verification key (placeholder)
GOOGLE_SEARCH_CONSOLE_KEY=

# --- App configuration ---
# Public base URL of the app (used for canonical URLs and links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public site name used in meta titles
NEXT_PUBLIC_SITE_NAME=Nova Nest Real Estate

# --- Upload configuration ---
# Max file size for uploads in bytes (default 5 MB)
MAX_FILE_SIZE=5242880
# Comma-separated list of allowed image types
ALLOWED_FILE_TYPES=jpg,jpeg,png,webp
